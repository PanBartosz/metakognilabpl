---
import PageIntro from '../../components/PageIntro.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { outputCategories, outputs, outputsPage } from '../../data/site';

const sections = outputCategories.map((category) => ({
	category,
	items: outputs.filter((item) => item.category === category),
}));
---

<SiteLayout title="Outputs" currentPath="/front-page/outputs/">
	<PageIntro title={outputsPage.title} lede={outputsPage.lede} />

	<section class="section-stack">
		{
			sections.map((section) => (
				<section class="output-section">
					<div class="section-heading">
						<h2>{section.category}</h2>
					</div>

					{
						section.items.length ? (
							<div class="archive-stack">
								{section.items.map((item) => (
									<article class="paper-panel archive-entry">
										<div class="meta-row">
											<span>{item.typeLabel}</span>
											<span>{item.dateLabel}</span>
										</div>
										<h3>{item.title}</h3>
										{item.venue ? <p class="link-card__note">{item.venue}</p> : null}
										{item.summary ? <p>{item.summary}</p> : null}
										{item.resources?.length ? (
											<div class="chip-row output-links">
												{item.resources.map((resource) => (
													<a
														href={resource.href}
														target={resource.external ? '_blank' : undefined}
														rel={resource.external ? 'noreferrer' : undefined}
														download={resource.download}
													>
														{resource.label}
													</a>
												))}
											</div>
										) : null}
										{item.href ? (
											<a class="text-link" href={item.href}>
												{item.linkLabel ?? 'Open output'}
											</a>
										) : null}
									</article>
								))}
							</div>
						) : (
							<article class="paper-panel output-empty">
								<p>No items listed yet.</p>
							</article>
						)
					}
				</section>
			))
		}
	</section>
</SiteLayout>
