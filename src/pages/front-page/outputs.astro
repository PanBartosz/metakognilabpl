---
import PageIntro from '../../components/PageIntro.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { outputCategories, outputs, outputsPage } from '../../data/site';

const sections = outputCategories.map((category) => ({
	category,
	items: outputs.filter((item) => item.category === category),
}));
---

<SiteLayout title="Outputs" currentPath="/front-page/outputs/" pageClass="page-outputs">
	<PageIntro title={outputsPage.title} lede={outputsPage.lede} />

	<section class="section-stack">
		{
			sections.map((section, sectionIndex) => (
				<section
					class="output-section"
					data-output-section
					style={`--output-section-index:${sectionIndex};`}
				>
					<div class="section-heading">
						<h2>{section.category}</h2>
					</div>

					{
						section.items.length ? (
							<div class="archive-stack">
								{section.items.map((item, itemIndex) => (
									<article
										class="paper-panel archive-entry"
										data-output-entry
										style={`--output-entry-index:${itemIndex};`}
									>
										<div class="meta-row">
											<span>{item.typeLabel}</span>
											<span>{item.dateLabel}</span>
										</div>
										<h3>{item.title}</h3>
										{item.venue ? <p class="link-card__note">{item.venue}</p> : null}
										{item.summary ? <p>{item.summary}</p> : null}
										{item.resources?.length ? (
											<div class="chip-row output-links">
												{item.resources.map((resource) => (
													<a
														href={resource.href}
														target={resource.external ? '_blank' : undefined}
														rel={resource.external ? 'noreferrer' : undefined}
														download={resource.download}
													>
														{resource.label}
													</a>
												))}
											</div>
										) : null}
										{item.href ? (
											<a class="text-link" href={item.href}>
												{item.linkLabel ?? 'Open output'}
											</a>
										) : null}
									</article>
								))}
							</div>
						) : (
							<article class="paper-panel output-empty" data-output-entry style="--output-entry-index:0;">
								<p>No items listed yet.</p>
							</article>
						)
					}
				</section>
			))
		}
	</section>
</SiteLayout>

<script is:inline>
	(() => {
		const revealOutputs = () => {
			const sections = Array.from(document.querySelectorAll('[data-output-section]'));
			const entries = Array.from(document.querySelectorAll('[data-output-entry]'));
			const targets = [...sections, ...entries];
			if (!targets.length) return;

			const shouldReduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			if (shouldReduceMotion || !('IntersectionObserver' in window)) {
				targets.forEach((target) => target.classList.add('is-visible'));
				return;
			}

			document.documentElement.classList.add('supports-output-motion');

			const observer = new IntersectionObserver(
				(observedEntries) => {
					observedEntries.forEach((entry) => {
						if (!entry.isIntersecting) return;
						entry.target.classList.add('is-visible');
						observer.unobserve(entry.target);
					});
				},
				{
					rootMargin: '0px 0px -12% 0px',
					threshold: 0.16,
				}
			);

			targets.forEach((target) => observer.observe(target));
		};

		if (!window.__metaOutputsMotionBound) {
			window.__metaOutputsMotionBound = true;
			document.addEventListener('astro:page-load', revealOutputs);
		}

		revealOutputs();
	})();
</script>
